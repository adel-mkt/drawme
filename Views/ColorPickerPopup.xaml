<UserControl x:Class="DrawMe.Views.ColorPickerPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="246">
    <Border Background="#1C2733" CornerRadius="10" Padding="14"
            BorderBrush="#2E3F52" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="6" Opacity="0.55"/>
        </Border.Effect>
        <StackPanel>

            <!-- Carré Saturation / Valeur -->
            <Grid x:Name="SvGrid" Height="130" Cursor="Cross"
                  MouseDown="SvGrid_MouseDown"
                  MouseMove="SvGrid_MouseMove"
                  MouseUp="SvGrid_MouseUp">
                <Rectangle x:Name="HueRect" RadiusX="6" RadiusY="6"/>
                <Rectangle RadiusX="6" RadiusY="6">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle RadiusX="6" RadiusY="6">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#FF000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Canvas x:Name="SvCanvas" IsHitTestVisible="False">
                    <Ellipse x:Name="SvThumb" Width="14" Height="14"
                             Stroke="White" StrokeThickness="2.5" Fill="Transparent">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="4" ShadowDepth="1" Opacity="0.7"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>
            </Grid>

            <!-- Slider Teinte (arc-en-ciel) -->
            <Grid x:Name="HueGrid" Height="16" Margin="0,10,0,0" Cursor="Hand"
                  MouseDown="HueGrid_MouseDown"
                  MouseMove="HueGrid_MouseMove"
                  MouseUp="HueGrid_MouseUp">
                <Rectangle RadiusX="8" RadiusY="8">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF0000" Offset="0"/>
                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                            <GradientStop Color="#00FF00" Offset="0.333"/>
                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                            <GradientStop Color="#0000FF" Offset="0.667"/>
                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                            <GradientStop Color="#FF0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Canvas x:Name="HueCanvas" IsHitTestVisible="False">
                    <Border x:Name="HueThumb" Width="6" Height="20" CornerRadius="3"
                            Background="White" BorderBrush="#666666" BorderThickness="1"
                            Canvas.Top="-2"/>
                </Canvas>
            </Grid>

            <!-- Slider Opacité -->
            <Grid x:Name="AlphaGrid" Height="16" Margin="0,8,0,0" Cursor="Hand"
                  MouseDown="AlphaGrid_MouseDown"
                  MouseMove="AlphaGrid_MouseMove"
                  MouseUp="AlphaGrid_MouseUp">
                <!-- Damier (transparence) -->
                <Rectangle RadiusX="8" RadiusY="8">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#AAAAAA">
                                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,8,8"/></GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="#777777">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <RectangleGeometry Rect="0,0,4,4"/>
                                                <RectangleGeometry Rect="4,4,4,4"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle x:Name="AlphaRect" RadiusX="8" RadiusY="8"/>
                <Canvas x:Name="AlphaCanvas" IsHitTestVisible="False">
                    <Border x:Name="AlphaThumb" Width="6" Height="20" CornerRadius="3"
                            Background="White" BorderBrush="#666666" BorderThickness="1"
                            Canvas.Top="-2"/>
                </Canvas>
            </Grid>

            <!-- Champ Hex + aperçu -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="#" Foreground="#7A8FA6" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="14" Margin="0,0,3,0"/>
                <TextBox x:Name="HexBox" Grid.Column="1"
                         FontFamily="Consolas" FontSize="13" CharacterCasing="Upper"
                         Foreground="White" Background="#253040"
                         CaretBrush="White" SelectionBrush="#3498DB"
                         BorderBrush="#2E3F52" BorderThickness="1"
                         Padding="6,5" MaxLength="8"
                         VerticalContentAlignment="Center"
                         TextChanged="HexBox_TextChanged"/>
                <Border Grid.Column="2" x:Name="PreviewSwatch" Margin="8,0,0,0"
                        CornerRadius="6" BorderBrush="#2E3F52" BorderThickness="1"/>
            </Grid>

            <!-- Couleurs prédéfinies -->
            <StackPanel x:Name="SwatchPanel" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,10,0,4"/>

        </StackPanel>
    </Border>
</UserControl>
